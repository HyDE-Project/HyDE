{
    "layer": "top",
    "output": [
        "*"
    ],
    "reload_style_on_change": true,
    "height": 10,
    "exclusive": true,
    "passthrough": false,
    "include": [
        "$XDG_CONFIG_HOME/waybar/modules/*json*",
        "$XDG_CONFIG_HOME/waybar/includes/includes.json"
    ],
    "group/pill-left": {
        "orientation": "inherit",
        "modules": [
            "custom/keybinhint",
            "custom/updates"
        ]
    },
    "group/pill-right": {
        "modules": [
            "battery",
            "custom/hyde-menu"
        ],
        "orientation": "inherit"
    },
    "group/pill-up": {
        "modules": [
            "wlr/taskbar"
        ],
        "orientation": "inherit"
    },
    "group/pill-down": {
        "modules": [
            "hyprland/workspaces"
        ],
        "orientation": "inherit"
    },
    "group/pill-in": {
        "modules": [
            "idle_inhibitor",
            "clock"
        ],
        "orientation": "inherit"
    },
    "group/pill-out": {
        "modules": [
            "custom/weather",
            "hyprland/language"
        ],
        "orientation": "inherit"
    },
    "group/leaf": {
        "orientation": "inherit",
        "modules": [
            "custom/workflows",
            "memory"
        ]
    },
    "group/leaf-inverse": {
        "modules": [
            "custom/gpuinfo",
            "custom/cpuinfo"
        ],
        "orientation": "inherit"
    },
    "group/pill-down#right": {
        "modules": [
            "pulseaudio",
            "pulseaudio#microphone",
            "tray"
        ],
        "orientation": "inherit"
    },
    "group/pill-up#right": {
        "modules": [
            "privacy",
            "custom/hyprsunset",
            "backlight#intel_backlight"
        ]
    },
    "modules-left": [
        "group/pill-left",
        "group/pill-down",
        "group/pill-up"
    ],
    "modules-center": [
        "group/leaf",
        "group/pill-in",
        "group/pill-in",
        "group/leaf-inverse"
    ],
    "modules-right": [
        "group/pill-up#right",
        "group/pill-down#right",
        "group/pill-right"
    ]
}
