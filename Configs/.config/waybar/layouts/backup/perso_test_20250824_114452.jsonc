{
    "layer": "top",
    "output": [
        "*"
    ],
    "reload_style_on_change": true,
    "height": 10,
    "exclusive": true,
    "passthrough": false,
    "include": [
        "$XDG_CONFIG_HOME/waybar/modules/*json*",
        "$XDG_CONFIG_HOME/waybar/includes/includes.json"
    ],
    "group/pill-left": {
        "orientation": "inherit",
        "modules": [
            "custom/keybinhint",
            "custom/updates"
        ]
    },
    "group/leaf": {
        "orientation": "inherit",
        "modules": [
            "custom/workflows",
            "memory"
        ]
    },
}
